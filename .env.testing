# ==============================================================================
# CVERIFY TESTING CONFIGURATION (.env.testing)
# ==============================================================================

# Active ASP.NET Environment
ASPNETCORE_ENVIRONMENT=Testing

# Database Settings
DB_HOST=localhost
DB_PORT=5434
DB_NAME=cverify_db_testing
DB_USER=postgres

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6380

# Ports & URLs
CORE_PORT=5248
AI_PORT=8001
FRONTEND_URL=http://localhost:3001

# Seeding & Safety
RESET_DATABASE=true
ALLOW_DEVELOPMENT_SEEDING=true
SEED_TEST_ACCOUNTS=true
DISABLE_RATE_LIMITS=true

# AI Service Settings
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLONE_DETECTION_ENABLED=false
ENABLE_VISION_CERTIFICATE_OCR=false
AI_DEBUG_MODE=true
AI_DEBUG_TOKENS=true
