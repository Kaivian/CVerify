# ==============================================================================
# CVERIFY PRODUCTION CONFIGURATION (.env.production)
# ==============================================================================

# Active ASP.NET Environment
ASPNETCORE_ENVIRONMENT=Production

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cverify_db_production
DB_USER=postgres

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Ports & URLs
CORE_PORT=5250
AI_PORT=8003
FRONTEND_URL=http://localhost:3003

# Seeding & Safety
RESET_DATABASE=false
ALLOW_DEVELOPMENT_SEEDING=false
SEED_TEST_ACCOUNTS=false
DISABLE_RATE_LIMITS=false

# AI Service Settings
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLONE_DETECTION_ENABLED=true
ENABLE_VISION_CERTIFICATE_OCR=false
AI_DEBUG_MODE=false
AI_DEBUG_TOKENS=false
