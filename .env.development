# ==============================================================================
# CVERIFY DEVELOPMENT CONFIGURATION (.env.development)
# ==============================================================================

# Active ASP.NET Environment
ASPNETCORE_ENVIRONMENT=Development

# Database Settings
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cverify_db_development
DB_USER=postgres

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Ports & URLs
CORE_PORT=5247
AI_PORT=8000
CLIENT_PORT=3000
FRONTEND_URL=http://localhost:3000

# Seeding & Safety
RESET_DATABASE=false
ALLOW_DEVELOPMENT_SEEDING=true
SEED_TEST_ACCOUNTS=true
DISABLE_RATE_LIMITS=true

# AI Service Settings
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLONE_DETECTION_ENABLED=false
ENABLE_VISION_CERTIFICATE_OCR=false
AI_DEBUG_MODE=false
AI_DEBUG_TOKENS=false
