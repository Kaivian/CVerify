# ==============================================================================
# CVERIFY SECRETS CONFIGURATION TEMPLATE (.env.secrets.example)
# ==============================================================================
# Copy this file to .env.secrets and configure the credentials.
# Values with 'GENERATE_SECURE_PASSWORD' etc. are automatically generated in setup.
# ==============================================================================

# Database & Cache Credentials
DB_PASSWORD=GENERATE_SECURE_PASSWORD
REDIS_PASSWORD=GENERATE_SECURE_PASSWORD

# Security Keys
JWT_KEY=GENERATE_JWT_SECRET_KEY
TOKEN_ENCRYPTION_KEY=GENERATE_TOKEN_ENCRYPTION_KEY
AI_SERVICE_SHARED_SECRET=GENERATE_AI_SHARED_SECRET

# Application Secrets
SUPER_ADMIN_PASSWORD=SuperAdminPassword123
SEED_BUSINESS_PASSWORD=TestPassword123
SMTP_PASSWORD=your_smtp_app_password_here

# Third-Party API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITLAB_CLIENT_ID=your_gitlab_client_id_here
GITLAB_CLIENT_SECRET=your_gitlab_client_secret_here

# Cloudflare R2 Secrets
ACCESS_KEY_ID=your_cloudflare_r2_access_key_id_here
SECRET_ACCESS_KEY=your_cloudflare_r2_secret_access_key_here
R2_ENDPOINT=your_cloudflare_r2_endpoint_here
R2_BUCKET=your_cloudflare_r2_bucket_here
